  "strategic_goals": [
    {
      "goal_id": "G1",
      "name": "Patient Safety Excellence",
      "category": "patient_safety",
      "description": "Achieve zero patient safety incidents and maintain the highest safety ratings",
      "owner_id": "medical_dir_001",
      "kpis": [
        { "kpi_id": "K1", "name": "Preventable Adverse Events", "target": "0 per quarter" },
        { "kpi_id": "K2", "name": "Protocol Compliance Rate", "target": "99.5%" }
      ],
      "priority": "critical"
    },
    {
      "goal_id": "G2",
      "name": "Regulatory and Data Compliance",
      "category": "regulatory_compliance",
      "description": "Full compliance with HIPAA, GDPR, and clinical governance frameworks",
      "owner_id": "cco_001",
      "kpis": [
        { "kpi_id": "K3", "name": "Regulatory Violation Count", "target": "Zero critical violations" },
        { "kpi_id": "K4", "name": "Data Privacy Incidents", "target": "Zero unauthorized disclosures" }
      ],
      "priority": "critical"
    },
    {
      "goal_id": "G3",
      "name": "Operational and Financial Efficiency",
      "category": "cost_efficiency",
      "description": "Reduce cost per patient by 12% through resource sharing and process improvement",
      "owner_id": "cfo_001",
      "kpis": [
        { "kpi_id": "K5", "name": "Cost per Patient", "target": "12% reduction YoY" },
        { "kpi_id": "K6", "name": "Equipment Utilization Rate", "target": "85%" }
      ],
      "priority": "high"
    }
  ],

  "risk_tolerance": {
    "financial": {
      "unbudgeted_spend_threshold": 100000,
      "high_cost_threshold": 500000,
      "critical_cost_threshold": 5000000
    },
    "compliance": {
      "hipaa_strict_mode": true,
      "gdpr_strict_mode": true,
      "audit_trail_required": true,
      "patient_consent_required": true
    }
  },

  "governance_rules": [
    {
      "rule_id": "R1",
      "name": "Capital Equipment Purchase Approval",
      "type": "financial",
      "description": "Medical equipment purchases exceeding the threshold require CFO approval and asset inventory review",
      "condition": { "field": "cost", "operator": ">", "value": 100000000 },
      "consequence": {
        "action": "require_approval",
        "approver_role": "Chief Financial Officer",
        "approver_id": "cfo_001",
        "severity": "high"
      },
      "active": true
    },
    {
      "rule_id": "R2",
      "name": "Patient Data Privacy and HIPAA Compliance",
      "type": "compliance",
      "description": "Decisions involving patient PII, clinical data access, or secondary data use require Compliance Officer review",
      "condition": {
        "operator": "OR",
        "conditions": [
          { "field": "uses_pii", "operator": "==", "value": true },
          { "field": "data_type", "operator": "contains", "value": "PHI" }
        ]
      },
      "consequence": {
        "action": "require_review",
        "approver_role": "Compliance Officer",
        "approver_id": "cco_001",
        "severity": "critical"
      },
      "active": true
    },
    {
      "rule_id": "R3",
      "name": "Critical Patient Safety Approval",
      "type": "strategic",
      "description": "Decisions with critical impact on patient safety require Medical Director approval",
      "condition": { "field": "strategic_impact", "operator": "==", "value": "critical" },
      "consequence": {
        "action": "require_approval",
        "approver_role": "Medical Director",
        "approver_id": "medical_dir_001",
        "severity": "critical"
      },
      "active": true
    },
    {
      "rule_id": "R4",
      "name": "Strategic Alignment Rule",
      "type": "strategic",
      "description": "Major clinical or technology decisions, or strategically significant decisions, must be linked to at least one hospital strategic goal",
      "condition": {
        "operator": "OR",
        "conditions": [
          { "field": "cost", "operator": ">", "value": 50000 },
          { "field": "strategic_impact", "operator": "==", "value": "high" },
          { "field": "strategic_impact", "operator": "==", "value": "critical" }
        ]
      },
      "consequence": {
        "action": "require_goal_mapping",
        "severity": "medium",
        "message": "The decision must be linked to at least one strategic goal (G1, G2, G3)"
      },
      "active": true
    },
    {
      "rule_id": "R5",
      "name": "Large Investment Board Approval",
      "type": "financial",
      "description": "Large investments require dual approval from the CFO and Hospital Administrator",
      "condition": { "field": "cost", "operator": ">", "value": 500000000 },
      "consequence": {
        "action": "require_approval",
        "approver_roles": ["Chief Financial Officer", "Hospital Administrator"],
        "approver_ids": ["cfo_001", "admin_001"],
        "severity": "critical",
        "requires_sequential": true
      },
      "active": true
    }
  ],

  "metadata": {
    "version": "2.0.0",
    "purpose": "Mayo Central Hospital Governance Framework Demo"
  }
}
