  "strategic_goals": [
    {
      "goal_id": "G1",
      "name": "Global Revenue Expansion",
      "category": "revenue_growth",
      "description": "Achieve 25% consolidated revenue growth through new market entry and M&A activities in 2025",
      "owner_id": "ceo_001",
      "kpis": [
        { "kpi_id": "K1", "name": "Revenue Growth Rate", "target": "25% increase YoY" },
        { "kpi_id": "K2", "name": "New Market Revenue", "target": "Achieve $50M ARR" }
      ],
      "priority": "high"
    },
    {
      "goal_id": "G2",
      "name": "Regulatory and Ethical Compliance",
      "category": "regulatory_compliance",
      "description": "Achieve zero critical compliance violations across all jurisdictions",
      "owner_id": "cco_001",
      "kpis": [
        { "kpi_id": "K3", "name": "Compliance Violation Count", "target": "Zero critical violations" },
        { "kpi_id": "K4", "name": "Audit Pass Rate", "target": "100%" }
      ],
      "priority": "critical"
    },
    {
      "goal_id": "G3",
      "name": "Operational Cost Efficiency",
      "category": "cost_efficiency",
      "description": "Reduce operating costs by 10% through vendor rationalization and process automation",
      "owner_id": "cfo_001",
      "kpis": [
        { "kpi_id": "K5", "name": "Operating Cost Reduction Rate", "target": "10% reduction YoY" },
        { "kpi_id": "K6", "name": "Cost-to-Revenue Ratio", "target": "Below 0.65" }
      ],
      "priority": "high"
    }
  ],

  "risk_tolerance": {
    "financial": {
      "unbudgeted_spend_threshold": 50000000,
      "high_cost_threshold": 250000000,
      "critical_cost_threshold": 1000000000
    },
    "compliance": {
      "audit_trail_required": true,
      "anti_bribery_policy": "zero_tolerance",
      "conflict_of_interest_review": "mandatory"
    }
  },

  "governance_rules": [
    {
      "rule_id": "R1",
      "name": "Capital Expenditure Approval",
      "type": "financial",
      "description": "Spending decisions exceeding budget thresholds require CFO approval",
      "condition": { "field": "cost", "operator": ">", "value": 50000000 },
      "consequence": {
        "action": "require_approval",
        "approver_role": "CFO",
        "approver_id": "cfo_001",
        "severity": "high"
      },
      "active": true
    },
    {
      "rule_id": "R2",
      "name": "Compliance and Ethics Review",
      "type": "compliance",
      "description": "Decisions involving related-party transactions, retroactive policy changes, or ESG violations require Compliance Officer review",
      "condition": {
        "operator": "OR",
        "conditions": [
          { "field": "counterparty_relation", "operator": "==", "value": "related_party" },
          { "field": "policy_change_type", "operator": "==", "value": "retroactive" },
          { "field": "involves_compliance_risk", "operator": "==", "value": true }
        ]
      },
      "consequence": {
        "action": "require_review",
        "approver_role": "Compliance Officer",
        "approver_id": "cco_001",
        "severity": "critical"
      },
      "active": true
    },
    {
      "rule_id": "R3",
      "name": "Critical Strategic Risk Rule",
      "type": "strategic",
      "description": "Decisions with critical strategic impact require CEO approval",
      "condition": { "field": "strategic_impact", "operator": "==", "value": "critical" },
      "consequence": {
        "action": "require_approval",
        "approver_role": "CEO",
        "approver_id": "ceo_001",
        "severity": "critical"
      },
      "active": true
    },
    {
      "rule_id": "R4",
      "name": "Strategic Alignment Rule",
      "type": "strategic",
      "description": "Major financial or strategically significant decisions must be linked to at least one strategic goal",
      "condition": {
        "operator": "OR",
        "conditions": [
          { "field": "cost", "operator": ">", "value": 50000000 },
          { "field": "strategic_impact", "operator": "==", "value": "high" },
          { "field": "strategic_impact", "operator": "==", "value": "critical" }
        ]
      },
      "consequence": {
        "action": "require_goal_mapping",
        "severity": "medium",
        "message": "The decision must be linked to at least one strategic goal (G1, G2, G3)"
      },
      "active": true
    },
    {
      "rule_id": "R5",
      "name": "Board-Level Approval",
      "type": "financial",
      "description": "Decisions exceeding the large investment threshold require sequential CFO and CEO approval",
      "condition": { "field": "cost", "operator": ">", "value": 1000000000 },
      "consequence": {
        "action": "require_approval",
        "approver_roles": ["CFO", "CEO"],
        "approver_ids": ["cfo_001", "ceo_001"],
        "severity": "critical",
        "requires_sequential": true
      },
      "active": true
    },
    {
      "rule_id": "R6",
      "name": "Personal Data and Security Review",
      "type": "privacy",
      "description": "Decisions involving processing, transfer, or exposure of customer PII require CISO review",
      "condition": { "field": "uses_pii", "operator": "==", "value": true },
      "consequence": {
        "action": "require_review",
        "approver_role": "CISO",
        "approver_id": "ciso_001",
        "severity": "high"
      },
      "active": true
    },
    {
      "rule_id": "R7",
      "name": "Workforce Hiring Review",
      "type": "hr",
      "description": "Decisions involving hiring or organizational changes require HR Team Lead review",
      "condition": { "field": "involves_hiring", "operator": "==", "value": true },
      "consequence": {
        "action": "require_review",
        "approver_role": "HR Team Lead",
        "approver_id": "hr_mgr_001",
        "severity": "medium"
      },
      "active": true
    },
    {
      "rule_id": "R8",
      "name": "Large-Scale Workforce Change Approval",
      "type": "hr",
      "description": "Decisions involving hiring 10+ employees or organizational restructuring require CEO approval",
      "condition": { "field": "headcount_change", "operator": ">=", "value": 10 },
      "consequence": {
        "action": "require_approval",
        "approver_role": "CEO",
        "approver_id": "ceo_001",
        "severity": "high"
      },
      "active": true
    }
  ],

