    "ko": {
      "company": {
        "id": "nexus_dynamics",
        "name": "넥서스 다이나믹스",
        "industry": "기업 금융",
        "industry_code": "FINANCE",
        "governance_framework": "기업 금융",
        "size": "1,200명 이상",
        "regions": [
          "한국 (본사)",
          "북미",
          "유럽",
          "동남아시아"
        ]
      },
      "rules": [
        {
          "rule_id": "R1",
          "name": "자본적 지출 승인",
          "type": "financial",
          "description": "예산 기준을 초과하는 지출 의사결정은 CFO 승인 필요",
          "condition": {
            "field": "cost",
            "operator": ">",
            "value": 50000000
          },
          "consequence": {
            "action": "require_approval",
            "approver_role": "CFO",
            "approver_id": "cfo_001",
            "severity": "high"
          },
          "active": true
        },
        {
          "rule_id": "R2",
          "name": "준법 및 윤리 검토",
          "type": "compliance",
          "description": "특수관계자 거래, 소급 정책 변경, ESG 위반 관련 의사결정은 준법감시인 검토 필요",
          "condition": {
            "operator": "OR",
            "conditions": [
              {
                "field": "counterparty_relation",
                "operator": "==",
                "value": "related_party"
              },
              {
                "field": "policy_change_type",
                "operator": "==",
                "value": "retroactive"
              },
              {
                "field": "involves_compliance_risk",
                "operator": "==",
                "value": true
              }
            ]
          },
          "consequence": {
            "action": "require_review",
            "approver_role": "준법감시인",
            "approver_id": "cco_001",
            "severity": "critical"
          },
          "active": true
        },
        {
          "rule_id": "R3",
          "name": "중대 전략 리스크 규정",
          "type": "strategic",
          "description": "중대한 전략적 영향을 수반하는 의사결정은 CEO 승인 필요",
          "condition": {
            "field": "strategic_impact",
            "operator": "==",
            "value": "critical"
          },
          "consequence": {
            "action": "require_approval",
            "approver_role": "CEO",
            "approver_id": "ceo_001",
            "severity": "critical"
          },
          "active": true
        },
        {
          "rule_id": "R4",
          "name": "전략 정합성 규정",
          "type": "strategic",
          "description": "주요 재무 의사결정 또는 전략적으로 중대한 의사결정은 최소 하나 이상의 전략 목표와 연계 필요",
          "condition": {
            "operator": "OR",
            "conditions": [
              {
                "field": "cost",
                "operator": ">",
                "value": 50000000
              },
              {
                "field": "strategic_impact",
                "operator": "==",
                "value": "high"
              },
              {
                "field": "strategic_impact",
                "operator": "==",
                "value": "critical"
              }
            ]
          },
          "consequence": {
            "action": "require_goal_mapping",
            "severity": "medium",
            "message": "의사결정은 최소 하나의 전략 목표(G1, G2, G3)와 연계되어야 합니다"
          },
          "active": true
        },
        {
          "rule_id": "R5",
          "name": "이사회급 승인",
          "type": "financial",
          "description": "대규모 투자 기준 초과 의사결정은 CFO 및 CEO 순차 승인 필요",
          "condition": {
            "field": "cost",
            "operator": ">",
            "value": 1000000000
          },
          "consequence": {
            "action": "require_approval",
            "approver_roles": [
              "CFO",
              "CEO"
            ],
            "approver_ids": [
              "cfo_001",
              "ceo_001"
            ],
            "severity": "critical",
            "requires_sequential": true
          },
          "active": true
        },
        {
          "rule_id": "R6",
          "name": "개인정보 및 보안 검토",
          "type": "privacy",
          "description": "고객 개인정보(PII) 처리·이전·노출이 수반되는 의사결정은 정보보호최고책임자(CISO) 검토 필요",
          "condition": {
            "field": "uses_pii",
            "operator": "==",
            "value": true
          },
          "consequence": {
            "action": "require_review",
            "approver_role": "정보보호최고책임자",
            "approver_id": "ciso_001",
            "severity": "high"
          },
          "active": true
        },
        {
          "rule_id": "R7",
          "name": "인력 채용 검토",
          "type": "hr",
          "description": "인력 채용 또는 조직 변경을 수반하는 의사결정은 인사팀장 검토 필요",
          "condition": {
            "field": "involves_hiring",
            "operator": "==",
            "value": true
          },
          "consequence": {
            "action": "require_review",
            "approver_role": "인사팀장",
            "approver_id": "hr_mgr_001",
            "severity": "medium"
          },
          "active": true
        },
        {
          "rule_id": "R8",
          "name": "대규모 인력 변경 승인",
          "type": "hr",
          "description": "10인 이상 인력 채용 또는 조직 구조 변경을 수반하는 의사결정은 CEO 승인 필요",
          "condition": {
            "field": "headcount_change",
            "operator": ">=",
            "value": 10
          },
          "consequence": {
            "action": "require_approval",
            "approver_role": "CEO",
            "approver_id": "ceo_001",
            "severity": "high"
          },
          "active": true
        }
      ],
