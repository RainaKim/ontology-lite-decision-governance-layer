# AWS Bedrock (required — powers all 8 Nova call sites)
BEDROCK_API_KEY=your_bedrock_api_key_here

# JWT Authentication
JWT_SECRET=your_jwt_secret_here

# Google OAuth2 (optional — for SSO login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Azure AD OIDC (optional — for SSO login)
# AZURE_CLIENT_ID=your_azure_client_id
# AZURE_CLIENT_SECRET=your_azure_client_secret
# AZURE_TENANT_ID=your_azure_tenant_id

# Token expiry (minutes, default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRES_MIN=10080

# SSO callback base URL
SSO_CALLBACK_BASE_URL=http://localhost:8000

# Frontend URL (for OAuth redirect)
FRONTEND_URL=http://localhost:5173

# Database (default: SQLite for dev, set PostgreSQL URL for production)
DATABASE_URL=sqlite:///./dev.db
