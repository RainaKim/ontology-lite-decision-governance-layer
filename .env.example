# LLM Provider (anthropic | openai | bedrock — default: anthropic)
LLM_PROVIDER=anthropic

# Anthropic (default provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (optional — set LLM_PROVIDER=openai to use)
# OPENAI_API_KEY=your_openai_api_key_here

# Model overrides (optional — defaults are set per provider in app/config/llm.py)
# LLM_MODEL_FAST=claude-haiku-4-5-20251001
# LLM_MODEL_CAPABLE=claude-sonnet-4-6

# Neo4j (local Docker: docker run -p 7474:7474 -p 7687:7687 -e NEO4J_AUTH=neo4j/password neo4j:5.11)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# JWT Authentication
JWT_SECRET=your_jwt_secret_here

# Google OAuth2 (optional — for SSO login)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# Azure AD OIDC (optional — for SSO login)
# AZURE_CLIENT_ID=your_azure_client_id
# AZURE_CLIENT_SECRET=your_azure_client_secret
# AZURE_TENANT_ID=your_azure_tenant_id

# Token expiry (minutes, default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRES_MIN=10080

# SSO callback base URL
SSO_CALLBACK_BASE_URL=http://localhost:8000

# Frontend URL (for OAuth redirect)
FRONTEND_URL=http://localhost:5173

# Database (default: SQLite for dev, set PostgreSQL URL for production)
DATABASE_URL=sqlite:///./dev.db
