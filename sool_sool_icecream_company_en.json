  "strategic_goals": [
    {
      "goal_id": "G1",
      "name": "Revenue Growth",
      "category": "revenue_growth",
      "description": "Increase annual revenue by 30% through social media marketing and new product launches",
      "owner_id": "ceo_001",
      "kpis": [
        {
          "kpi_id": "K1",
          "name": "Monthly Revenue Growth",
          "target": "20% increase in monthly revenue"
        },
        {
          "kpi_id": "K2",
          "name": "New Customer Acquisition",
          "target": "30% new customers"
        }
      ],
      "priority": "high"
    },

    {
      "goal_id": "G2",
      "name": "Product Innovation",
      "category": "product_innovation",
      "description": "Launch new ice cream flavors every quarter",
      "owner_id": "rnd_lead_001",
      "kpis": [
        {
          "kpi_id": "K3",
          "name": "New Product Launch",
          "target": "At least 1 new flavor per quarter"
        }
      ],
      "priority": "high"
    },

    {
      "goal_id": "G3",
      "name": "Operational Cost Stability",
      "category": "cost_stability",
      "description": "Maintain stable operating costs through optimized inventory and supply chain management",
      "owner_id": "finance_mgr_001",
      "kpis": [
        {
          "kpi_id": "K4",
          "name": "Inventory Turnover",
          "target": "At least twice per month"
        }
      ],
      "priority": "medium"
    }
  ],

  "risk_tolerance": {
    "financial": {
      "unbudgeted_spend_threshold": 1500,
      "high_cost_threshold": 5000,
      "critical_cost_threshold": 10000
    },

    "operations": {
      "inventory_shortage_risk": "high",
      "production_capacity_limit": true
    }
  },

  "governance_rules": [
    {
      "rule_id": "R1",
      "name": "Large Purchase Approval",
      "type": "financial",
      "description": "Purchases exceeding $1,500 require Operations Manager approval",
      "condition": {
        "field": "cost",
        "operator": ">",
        "value": 1500
      },
      "consequence": {
        "action": "require_approval",
        "approver_role": "Operations Manager",
        "approver_id": "ops_mgr_001",
        "severity": "high"
      },
      "active": true
    },

    {
      "rule_id": "R2",
      "name": "Duplicate Procurement Check",
      "type": "procurement",
      "description": "If additional inventory is already in transit, new orders must be reviewed",
      "condition": {
        "field": "existing_order_in_transit",
        "operator": "==",
        "value": true
      },
      "consequence": {
        "action": "require_review",
        "approver_role": "Procurement Lead",
        "approver_id": "procurement_lead_001",
        "severity": "medium"
      },
      "active": true
    },

    {
      "rule_id": "R3",
      "name": "Production Capacity Check",
      "type": "operations",
      "description": "Decisions that may exceed production capacity require Operations Manager review",
      "condition": {
        "field": "production_capacity_exceeded",
        "operator": "==",
        "value": true
      },
      "consequence": {
        "action": "require_review",
        "approver_role": "Operations Manager",
        "approver_id": "ops_mgr_001",
        "severity": "high"
      },
      "active": true
    },

    {
      "rule_id": "R4",
      "name": "New Product Development Review",
      "type": "strategic",
      "description": "New product development must be reviewed by the R&D Lead",
      "condition": {
        "field": "new_product_development",
        "operator": "==",
        "value": true
      },
      "consequence": {
        "action": "require_review",
        "approver_role": "R&D Lead",
        "approver_id": "rnd_lead_001",
        "severity": "medium"
      },
      "active": true
    },

    {
      "rule_id": "R5",
      "name": "Hiring Approval Policy",
      "type": "hr",
      "description": "New hiring decisions must be reviewed against financial status and production capacity. Finance Manager validates budget feasibility first; CEO approves after.",
      "condition": {
        "field": "involves_hiring",
        "operator": "==",
        "value": true
      },
      "consequence": {
        "action": "require_review",
        "approver_roles": ["Finance Manager", "CEO"],
        "approver_ids": ["finance_mgr_001", "ceo_001"],
        "requires_sequential": true,
        "severity": "high",
        "message_en": "Finance Manager must confirm cash-flow plan and year-end financial projection before CEO approval"
      },
      "active": true
    }
  ],

  "metadata": {
    "version": "1.0.0",
