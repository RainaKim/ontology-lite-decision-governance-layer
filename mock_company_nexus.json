    "en": {
      "company": {
        "id": "nexus_dynamics",
        "name": "Nexus Dynamics",
        "industry": "Corporate Finance",
        "industry_code": "FINANCE",
        "governance_framework": "Corporate Finance",
        "size": "1,200+ employees",
        "regions": [
          "South Korea (HQ)",
          "North America",
          "Europe",
          "Southeast Asia"
        ]
      },
      "rules": [
        {
          "rule_id": "R1",
          "name": "Capital Expenditure Approval",
          "type": "financial",
          "description": "Spending decisions exceeding budget thresholds require CFO approval",
          "condition": {
            "field": "cost",
            "operator": ">",
            "value": 50000000
          },
          "consequence": {
            "action": "require_approval",
            "approver_role": "CFO",
            "approver_id": "cfo_001",
            "severity": "high"
          },
          "active": true
        },
        {
          "rule_id": "R2",
          "name": "Compliance and Ethics Review",
          "type": "compliance",
          "description": "Decisions involving related-party transactions, retroactive policy changes, or ESG violations require Compliance Officer review",
          "condition": {
            "operator": "OR",
            "conditions": [
              {
                "field": "counterparty_relation",
                "operator": "==",
                "value": "related_party"
              },
              {
                "field": "policy_change_type",
                "operator": "==",
                "value": "retroactive"
              },
              {
                "field": "involves_compliance_risk",
                "operator": "==",
                "value": true
              }
            ]
          },
          "consequence": {
            "action": "require_review",
            "approver_role": "Compliance Officer",
            "approver_id": "cco_001",
            "severity": "critical"
          },
          "active": true
        },
        {
          "rule_id": "R3",
          "name": "Critical Strategic Risk Rule",
          "type": "strategic",
          "description": "Decisions with critical strategic impact require CEO approval",
          "condition": {
            "field": "strategic_impact",
            "operator": "==",
            "value": "critical"
          },
          "consequence": {
            "action": "require_approval",
            "approver_role": "CEO",
            "approver_id": "ceo_001",
            "severity": "critical"
          },
          "active": true
        },
        {
          "rule_id": "R4",
          "name": "Strategic Alignment Rule",
          "type": "strategic",
          "description": "Major financial or strategically significant decisions must be linked to at least one strategic goal",
          "condition": {
            "operator": "OR",
            "conditions": [
              {
                "field": "cost",
                "operator": ">",
                "value": 50000000
              },
              {
                "field": "strategic_impact",
                "operator": "==",
                "value": "high"
              },
              {
                "field": "strategic_impact",
                "operator": "==",
                "value": "critical"
              }
            ]
          },
          "consequence": {
            "action": "require_goal_mapping",
            "severity": "medium",
            "message": "The decision must be linked to at least one strategic goal (G1, G2, G3)"
          },
          "active": true
        },
        {
          "rule_id": "R5",
          "name": "Board-Level Approval",
          "type": "financial",
          "description": "Decisions exceeding the large investment threshold require sequential CFO and CEO approval",
          "condition": {
            "field": "cost",
            "operator": ">",
            "value": 1000000000
          },
          "consequence": {
            "action": "require_approval",
            "approver_roles": [
              "CFO",
              "CEO"
            ],
            "approver_ids": [
              "cfo_001",
              "ceo_001"
            ],
            "severity": "critical",
            "requires_sequential": true
          },
          "active": true
        },
        {
          "rule_id": "R6",
          "name": "Personal Data and Security Review",
          "type": "privacy",
          "description": "Decisions involving processing, transfer, or exposure of customer PII require CISO review",
          "condition": {
            "field": "uses_pii",
            "operator": "==",
            "value": true
          },
          "consequence": {
            "action": "require_review",
            "approver_role": "CISO",
            "approver_id": "ciso_001",
            "severity": "high"
          },
          "active": true
        },
        {
          "rule_id": "R7",
          "name": "Workforce Hiring Review",
          "type": "hr",
          "description": "Decisions involving hiring or organizational changes require HR Team Lead review",
          "condition": {
            "field": "involves_hiring",
            "operator": "==",
            "value": true
          },
          "consequence": {
            "action": "require_review",
            "approver_role": "HR Team Lead",
            "approver_id": "hr_mgr_001",
            "severity": "medium"
          },
          "active": true
        },
        {
          "rule_id": "R8",
          "name": "Large-Scale Workforce Change Approval",
          "type": "hr",
          "description": "Decisions involving hiring 10+ employees or organizational restructuring require CEO approval",
          "condition": {
            "field": "headcount_change",
            "operator": ">=",
            "value": 10
          },
          "consequence": {
            "action": "require_approval",
            "approver_role": "CEO",
            "approver_id": "ceo_001",
            "severity": "high"
          },
          "active": true
        }
      ],
